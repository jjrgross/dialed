# =============================================================================
# Dialed — Environment Variables
# Copy to .env.local (web) and configure per-app as noted below.
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk (Auth) — https://dashboard.clerk.com
# Mobile: set in mobile/.env or app.config extra
# Web: set in web/.env.local
# Convex: set in Convex dashboard → Settings → Environment Variables
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-domain.clerk.accounts.dev
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# Convex — https://dashboard.convex.dev
# -----------------------------------------------------------------------------
CONVEX_DEPLOYMENT=dev:your-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# -----------------------------------------------------------------------------
# Resend (Email) — set in Convex dashboard
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Dialed <hello@yourdomain.com>

# -----------------------------------------------------------------------------
# PostHog (Analytics)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_POSTHOG_KEY=phc_...
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Sentry (Error tracking)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# -----------------------------------------------------------------------------
# RevenueCat (Payments — mobile)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...

# -----------------------------------------------------------------------------
# Adapty (Subscriptions — mobile)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_ADAPTY_PUBLIC_KEY=public_live_...

# -----------------------------------------------------------------------------
# AppsFlyer (Attribution — mobile)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_APPSFLYER_DEV_KEY=...
EXPO_PUBLIC_APPSFLYER_APP_ID=id123456789
